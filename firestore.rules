rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY: Open access for all authenticated users to debug deployment issues
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow the test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
