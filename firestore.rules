rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      function isChatOwner() { 
        return request.auth != null && resource != null && resource.data.userId == request.auth.uid;
      }
      allow read: if isChatOwner();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isChatOwner() && request.resource.data.userId == request.auth.uid;
      allow delete: if isChatOwner();
    }

    match /accessKeys/{keyId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || keyId == 'key_' + request.auth.uid);
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || keyId == 'key_' + request.auth.uid);
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || keyId == 'key_' + request.auth.uid);
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || keyId == 'key_' + request.auth.uid);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
