{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "messages": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "messages", "createdAt"]
    },
    "AccessKey": {
      "title": "AccessKey",
      "description": "GenGenius Internal Access Key",
      "type": "object",
      "properties": {
        "keyId": { "type": "string" },
        "userId": { "type": "string" },
        "usageCount": { "type": "integer" },
        "lastResetTimestamp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["keyId", "userId", "usageCount", "lastResetTimestamp", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "/accessKeys/{keyId}": {
      "schema": "AccessKey",
      "description": "Internal access keys for rate limiting"
    }
  }
}
